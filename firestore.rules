// firestore.rules
// Разверните эти правила в Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Читать могут все (публичная карта)
      allow read: if true;

      // Писать может любой (без авторизации для MVP)
      // Для продакшн — добавьте авторизацию!
      allow create: if request.resource.data.keys().hasAll(['animal','emoji','label','lat','lng','timestamp'])
                    && request.resource.data.lat is number
                    && request.resource.data.lng is number;

      // Обновление/удаление — только через Admin SDK (сервер)
      allow update, delete: if false;
    }
  }
}
